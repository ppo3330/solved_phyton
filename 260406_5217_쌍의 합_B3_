#O(T*N*N)

T = int(input())
for _ in range(T):
    N = int(input())
    res = "Pairs for " + str(N) + ": "
    for i in range(N):
        for j in range(i+1,N):
          if i + j == N:
            res += str(i) + " " + str(j) + (", ")
    if len(res) != 13:
      res = res[:len(res)-2]
    print(res)
